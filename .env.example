# Shopify Storefront API — required for product/collection/cart data
SHOPIFY_STORE_DOMAIN=mrteashop-com.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Shopify Admin API — server-only, never exposed to the browser
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# Public site URL — used for JSON-LD structured data and canonical URLs
NEXT_PUBLIC_SITE_URL=https://teavision.com.au

# Trustoo (TrustWILL) product reviews widget
# Shop's myshopify domain — identifies the store to the Trustoo widget
NEXT_PUBLIC_TRUSTOO_SHOP_DOMAIN=mrteashop-com.myshopify.com

# Searchanise product recommendation widget
# Public API key from Searchanise dashboard; set enabled to true to render the widget.
NEXT_PUBLIC_SEARCHANISE_ENABLED=false
NEXT_PUBLIC_SEARCHANISE_API_KEY=

# Resend — required in production for /pages/contact enquiries
# Verify noreply@teavision.com.au or the teavision.com.au sending domain in Resend before enabling.
RESEND_API_KEY=
