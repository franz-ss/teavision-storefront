# Shopify Storefront API — required for product/collection/cart data
SHOPIFY_STORE_DOMAIN=mrteashop-com.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Shopify Customer Account API — required for /account OAuth and customer data.
# Local OAuth testing requires a public HTTPS tunnel configured in Shopify
# customer account callback and logout URLs.
SHOPIFY_CUSTOMER_ACCOUNT_API_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_SESSION_SECRET=
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=
SHOPIFY_CUSTOMER_ACCOUNT_LOGOUT_REDIRECT_URI=
# Optional fake Customer Account endpoints for automated tests only.
SHOPIFY_CUSTOMER_ACCOUNT_TEST_MODE=false
SHOPIFY_CUSTOMER_ACCOUNT_TEST_URL=

# Shopify Admin API — server-only, never exposed to the browser
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# Site URL — used for JSON-LD structured data and canonical URLs
SITE_URL=https://teavision.com.au

# Launch gate — keep review and staging environments out of search indexes.
# Set false only for the owner-approved launch deployment.
DISABLE_INDEXING=true

# Sanity CMS — blog content and images
NEXT_PUBLIC_SANITY_PROJECT_ID=u8zt9l5y
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-28
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# Trustoo (TrustWILL) product reviews widget
# Shop's myshopify domain — identifies the store to the Trustoo widget
NEXT_PUBLIC_TRUSTOO_SHOP_DOMAIN=mrteashop-com.myshopify.com

# Searchanise product recommendation widget
# Public API key from the Searchanise dashboard, not the recommendation widget DOM id.
# Teavision's current widget DOM id is handled in code: 1T8K1Y6Q6G8R3B3.
NEXT_PUBLIC_SEARCHANISE_ENABLED=false
NEXT_PUBLIC_SEARCHANISE_API_KEY=

# Consent-aware analytics destinations — public IDs only, never secrets.
# Keep fake/disabled for local and CI. Enable live IDs only after owner approval.
NEXT_PUBLIC_ANALYTICS_MODE=fake
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
NEXT_PUBLIC_SHOPIFY_PIXEL_ENABLED=false

# Resend — required for newsletter signup and /pages/contact enquiries
# Without this key every newsletter/contact submission returns a user-safe send-error.
# Obtain from: Resend Dashboard -> API Keys (https://resend.com/api-keys)
# Verify noreply@teavision.com.au or the teavision.com.au sending domain in Resend before enabling.
RESEND_API_KEY=

# Rate limiting - production must be explicit.
# Set RATE_LIMIT_EXTERNAL_PROTECTION=true when the host/CDN/WAF enforces public form/search limits.
# Set RATE_LIMIT_ALLOW_MEMORY_FALLBACK=true only when intentionally accepting per-instance memory limits.
# RATE_LIMIT_TRUSTED_IP_HEADER must be one of x-forwarded-for, x-real-ip, or cf-connecting-ip.
RATE_LIMIT_EXTERNAL_PROTECTION=false
RATE_LIMIT_ALLOW_MEMORY_FALLBACK=false
RATE_LIMIT_TRUSTED_IP_HEADER=x-forwarded-for
