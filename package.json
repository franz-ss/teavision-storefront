{
  "name": "teavision-com-au",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:contracts": "node --test scripts/eslint-rules/*.test.mjs scripts/component-contracts/*.test.mjs",
    "test:unit": "vitest run --environment node tests/setup/smoke.test.ts src/lib/env/read.test.ts src/lib/seo/site-url.test.ts src/lib/shopify/client.test.ts src/lib/shopify/quantity-rules.test.ts src/lib/shopify/operations/cart.test.ts src/lib/shopify/operations/product.test.ts src/components/collection/loading-skeleton/loading-skeleton.test.tsx src/components/layout/header/search-autocomplete.test.tsx src/components/product/product-form/product-form.test.tsx \"src/app/(storefront)/cart/_components/cart-loading-skeleton.test.tsx\" \"src/app/(storefront)/cart/_components/cart-recommendations.test.tsx\" \"src/app/(storefront)/cart/_components/cart-view.test.tsx\" \"src/app/(storefront)/products/[handle]/_components/related-products.test.tsx\"",
    "test:integration": "vitest run --environment node src/lib/cart/actions.test.ts \"src/app/api/products/[handle]/quick-view/route.test.ts\"",
    "test:e2e": "playwright test",
    "test:stories": "vitest run --config vitest.storybook.config.mts",
    "lint": "node scripts/check-tailwind-classes.mjs && eslint .",
    "lint:tailwind": "node scripts/check-tailwind-classes.mjs",
    "format": "prettier --write .",
    "codegen": "dotenv -e .env.local graphql-codegen",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "create:component": "node scripts/create-component.mjs",
    "create:lib": "node scripts/create-lib.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/image-url": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.13.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-sanity": "^13.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "sanitize-html": "^2.17.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/browser-playwright": "^4.1.8",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.4.1",
    "husky": "^9.1.7",
    "lighthouse": "^13.2.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.1",
    "tailwindcss": "4.2.4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
